# Public REST API base URL (browser-exposed). Backend Express + Drizzle service.
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Public Socket.IO endpoint (browser-exposed). Use ws:// for HTTP pages, wss:// for HTTPS pages.
NEXT_PUBLIC_SOCKET_URL=ws://localhost:3000

# Server-only: backend URL the /api/contact route forwards email submissions to.
EMAIL_BACKEND_URL=http://localhost:3000
